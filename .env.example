# DotnetRoutix Server environment variables
# Use these to match ZIPTen Node OTP/email behavior.

# ASP.NET hosting
ASPNETCORE_URLS=http://localhost:5008

# MongoDB
MongoDb__ConnectionString=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/
MongoDb__DatabaseName=lunchbox

# OTP flow
Otp__DebugMode=true
Otp__ExpiryMinutes=10
Otp__RequireOtpOnLogin=false

# Email (Gmail SMTP)
Email__Provider=gmail
Email__GmailUser=
Email__GmailAppPassword=
Email__GmailFromEmail=
Email__SmtpHost=smtp.gmail.com
Email__SmtpPort=587
Email__EnableSsl=true

# Node-style fallback variables also supported by SmtpEmailSender
GMAIL_USER=
GMAIL_APP_PASSWORD=
GMAIL_FROM_EMAIL=
